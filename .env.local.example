# ============================================================
# ResumeBoost — environment variables
# Copy this file to .env.local and fill in the real values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# All others are SERVER-ONLY — never expose them client-side.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY   # server-only

# ── Groq (AI — replaces n8n) ─────────────────────────────────
# https://console.groq.com → API Keys
GROQ_API_KEY=YOUR_GROQ_API_KEY                             # server-only

# ── YouTube Data API v3 ───────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
# Enable "YouTube Data API v3" in the same project first.
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY                       # server-only

# ── Resend (email) ────────────────────────────────────────────
# https://resend.com → API Keys
RESEND_API_KEY=YOUR_RESEND_API_KEY                         # server-only

# ── Stripe ────────────────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY                   # server-only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_PRICE_ID=YOUR_STRIPE_PRO_PRICE_ID                   # server-only
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET           # server-only

# ── Vercel Cron secret ────────────────────────────────────────
# A random secret you generate (e.g. openssl rand -hex 32).
# Used to protect the /api/cron/job-alerts endpoint.
CRON_SECRET=YOUR_CRON_SECRET                               # server-only

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
